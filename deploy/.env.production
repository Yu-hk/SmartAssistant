# =============================================================================
# SmartAssistant - 生产环境变量模板
# 复制为 .env 并填入真实值，放置于 deploy/ 目录下
# 使用：docker compose --env-file .env up -d
#
# ⚠️ 安全须知：
#   1. 本文件仅为占位符模板，禁止在此填入任何真实密钥。
#   2. 真实密钥请写入 deploy/.env（已被 .gitignore 忽略，不会入库）。
#   3. 所有 CHANGE_ME_* 均须替换为强随机值后方可用于生产。
# =============================================================================

# --- DeepSeek API ---
DEEPSEEK_API_KEY=CHANGE_ME_deepseek_api_key

# --- PostgreSQL ---
POSTGRES_DB=a2a_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_password

# --- Nacos ---
NACOS_USERNAME=nacos
NACOS_PASSWORD=CHANGE_ME_nacos_password
# NACOS_AUTH_TOKEN 必须为 Base64 编码且至少 32 字节；可用：openssl rand -base64 48
NACOS_AUTH_TOKEN=CHANGE_ME_base64_min_32_bytes_nacos_auth_token

# --- JWT（至少 256 bit；可用：openssl rand -base64 48）---
JWT_SECRET=CHANGE_ME_jwt_secret_min_256_bit

# --- Grafana（监控面板管理员）---
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password

# --- MinIO（Milvus 对象存储）---
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key
