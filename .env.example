# SmartAssistant 环境变量配置模板
# 复制此文件为 .env，填入真实值后使用
# ⚠️ 注意：.env 文件已加入 .gitignore，不会提交到版本控制

# =======================================
# 深度求索 DeepSeek API
# =======================================
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# =======================================
# 阿里云 DashScope API
# =======================================
# 申请地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-api-key-here

# =======================================
# 高德地图 API
# =======================================
# 申请地址：https://lbs.amap.com/
AMAP_API_KEY=your-amap-api-key-here

# =======================================
# PostgreSQL 数据库
# =======================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=a2a_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password-here

# =======================================
# Redis
# =======================================
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password-here  # 如果 Redis 设置了密码

# =======================================
# JWT 配置
# =======================================
# 建议使用 256 位随机字符串
JWT_SECRET=your-jwt-secret-key-at-least-256-bits-long

# =======================================
# Nacos 服务注册
# =======================================
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP

# =======================================
# HanLP 数据路径（可选）
# =======================================
# 如不配置，HanLP 会自动从 classpath:/data 或用户目录 ~/.hanlp 查找
# HANLP_DATA_PATH=D:/workspace/SmartAssistant/hanlp-data

# =======================================
# 监控配置（可选）
# =======================================
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
# GRAFANA_ADMIN_PASSWORD=admin
