    {
      "id": 1,
      "title": "缓存预热概览",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(cache_preload_total_total[1h]))",
          "legendFormat": "总预热次数",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(cache_preload_success_total[1h]))",
          "legendFormat": "成功次数",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(cache_preload_failure_total[1h]))",
          "legendFormat": "失败次数",
          "refId": "C"
        }
