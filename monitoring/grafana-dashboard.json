{
  "__inputs": [],
  "__requires": [],
  "dashboard": {
    "title": "SmartAssistant 微服务全景监控",
    "tags": ["smartassistant", "spring-boot", "microservices"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "time": { "from": "now-15m", "to": "now" },
    "timepicker": { "refresh_intervals": ["5s","10s","30s","1m","5m","15m","30m"] },
    "panels": [
      {
        "id": 1, "title": "服务健康状态", "type": "stat",
        "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "count(up{team=\"smartassistant\"} == 1)",
            "legendFormat": "运行中"
          },
          {
            "expr": "count(up{team=\"smartassistant\"} == 0)",
            "legendFormat": "宕机"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "center",
          "orientation": "horizontal",
          "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
          "textMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "red", "value": 1 },
                { "color": "green", "value": 6 }
              ]
            },
            "color": { "mode": "thresholds" }
          },
          "overrides": []
        }
      },
      {
        "id": 2, "title": "JVM 堆内存使用率（按服务）", "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "sum(jvm_memory_used_bytes{area=\"heap\",team=\"smartassistant\"}) by (service) / sum(jvm_memory_max_bytes{area=\"heap\",team=\"smartassistant\"}) by (service) * 100",
            "legendFormat": "{{service}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "orange", "value": 70 },
                { "color": "red", "value": 90 }
              ]
            },
            "color": { "mode": "palette-classic" }
          }
        },
        "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
      },
      {
        "id": 3, "title": "JVM 堆内存绝对值（按服务）", "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "sum(jvm_memory_used_bytes{area=\"heap\",team=\"smartassistant\"}) by (service)",
            "legendFormat": "{{service}} 已用"
          },
          {
            "expr": "sum(jvm_memory_max_bytes{area=\"heap\",team=\"smartassistant\"}) by (service)",
            "legendFormat": "{{service}} 最大",
            "lineStyle": { "fill": "dash", "dash": [10, 10] }
          }
        ],
        "fieldConfig": { "defaults": { "unit": "decbytes" } },
        "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
      },
      {
        "id": 4, "title": "HTTP 请求速率（按服务）", "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{team=\"smartassistant\"}[1m])",
            "legendFormat": "{{service}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "reqps" } },
        "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
      },
      {
        "id": 5, "title": "HTTP 请求延迟 P99（按服务）", "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{team=\"smartassistant\"}[1m])) by (service, le))",
            "legendFormat": "{{service}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "s" } },
        "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
      },
      {
        "id": 6, "title": "HTTP 错误率（按服务）", "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
        "targets": [
          {
            "expr": "sum(rate(http_server_requests_seconds_count{team=\"smartassistant\", outcome!=\"SUCCESS\"}[1m])) by (service) / sum(rate(http_server_requests_seconds_count{team=\"smartassistant\"}[1m])) by (service) * 100",
            "legendFormat": "{{service}}"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "percent", "min": 0 },
          "overrides": []
        },
        "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
      },
      {
        "id": 7, "title": "GC 暂停耗时（按服务）", "type": "timeseries",
        "gridPos": { "h": 7, "w": 8, "x": 0, "y": 20 },
        "targets": [
          {
            "expr": "rate(jvm_gc_pause_seconds_sum{team=\"smartassistant\"}[1m])",
            "legendFormat": "{{service}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "s" } },
        "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
      },
      {
        "id": 8, "title": "CPU 使用率（按服务）", "type": "timeseries",
        "gridPos": { "h": 7, "w": 8, "x": 8, "y": 20 },
        "targets": [
          {
            "expr": "system_cpu_usage{team=\"smartassistant\"} * 100",
            "legendFormat": "{{service}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
        "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
      },
      {
        "id": 9, "title": "活跃线程数（按服务）", "type": "timeseries",
        "gridPos": { "h": 7, "w": 8, "x": 16, "y": 20 },
        "targets": [
          {
            "expr": "jvm_threads_live_threads{team=\"smartassistant\"}",
            "legendFormat": "{{service}}"
          }
        ],
        "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
      },
      {
        "id": 10, "title": "各服务 Heap 内存实时水位", "type": "bargauge",
        "gridPos": { "h": 6, "w": 12, "x": 0, "y": 27 },
        "targets": [
          {
            "expr": "sum(jvm_memory_used_bytes{area=\"heap\",team=\"smartassistant\"}) by (service) / sum(jvm_memory_max_bytes{area=\"heap\",team=\"smartassistant\"}) by (service) * 100",
            "legendFormat": "{{service}}"
          }
        ],
        "options": {
          "orientation": "horizontal",
          "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "orange", "value": 70 },
                { "color": "red", "value": 90 }
              ]
            }
          }
        }
      },
      {
        "id": 11, "title": "HTTP 请求延迟热力图（P50/P90/P99）- 整体", "type": "timeseries",
        "gridPos": { "h": 6, "w": 12, "x": 12, "y": 27 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.90, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
            "legendFormat": "P90"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket[1m])) by (le))",
            "legendFormat": "P99"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "s" } },
        "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
      },
      {
        "id": 12, "title": "L3 意图融合来源分布", "type": "piechart",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
        "targets": [
          { "expr": "sum(rate(a2a_intent_fusion_source{source=\"rule\"}[5m]))", "legendFormat": "规则" },
          { "expr": "sum(rate(a2a_intent_fusion_source{source=\"classifier\"}[5m]))", "legendFormat": "小模型" },
          { "expr": "sum(rate(a2a_intent_fusion_source{source=\"llm\"}[5m]))", "legendFormat": "LLM" },
          { "expr": "sum(rate(a2a_intent_fusion_source{source=\"fallback\"}[5m]))", "legendFormat": "兜底" }
        ],
        "options": {
          "legend": { "displayMode": "table", "placement": "right" },
          "pieType": "pie",
          "reduceOptions": { "calcs": ["lastNotNull"] }
        },
        "fieldConfig": { "defaults": { "unit": "cps" } }
      },
      {
        "id": 13, "title": "意图漂移 & 预算超限", "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
        "targets": [
          { "expr": "sum(rate(a2a_intent_drift_total{level=\"drift\"}[5m]))", "legendFormat": "漂移" },
          { "expr": "sum(rate(a2a_intent_drift_total{level=\"strong\"}[5m]))", "legendFormat": "强漂移" },
          { "expr": "sum(rate(a2a_budget_exceeded_total[5m]))", "legendFormat": "预算超限" }
        ],
        "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
        "fieldConfig": { "defaults": { "unit": "cps" } }
      },
      {
        "id": 14, "title": "工具执行状态 & 熔断", "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
        "targets": [
          { "expr": "sum(rate(a2a_tool_execution_result{status=\"success\"}[5m]))", "legendFormat": "执行成功" },
          { "expr": "sum(rate(a2a_tool_execution_result{status=\"failed\"}[5m]))", "legendFormat": "执行失败" },
          { "expr": "sum(rate(a2a_tool_circuit_breaker[5m]))", "legendFormat": "熔断触发" }
        ],
        "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
        "fieldConfig": { "defaults": { "unit": "cps" } }
      },
      {
        "id": 15, "title": "工具错误类型分布", "type": "piechart",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 41 },
        "targets": [
          { "expr": "sum(rate(a2a_tool_error_type[5m])) by (error)", "legendFormat": "{{error}}" }
        ],
        "options": {
          "legend": { "displayMode": "table", "placement": "right", "values": ["percent"] },
          "pieType": "pie",
          "reduceOptions": { "calcs": ["sum"], "fields": "/.*/" },
          "tooltip": { "mode": "single", "sort": "desc" }
        },
        "fieldConfig": {
          "defaults": { "unit": "cps" },
          "overrides": [
            { "matcher": { "id": "byName", "options": "retryable" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f2cc60" } }] },
            { "matcher": { "id": "byName", "options": "fatal" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#e24d42" } }] }
          ]
        }
      },
      {
        "id": 16, "title": "工具执行延迟分位数(p50/p95/p99)", "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 41 },
        "targets": [
          { "expr": "histogram_quantile(0.50, sum(rate(a2a_tool_execution_latency_percentile_bucket[5m])) by (le))", "legendFormat": "p50" },
          { "expr": "histogram_quantile(0.95, sum(rate(a2a_tool_execution_latency_percentile_bucket[5m])) by (le))", "legendFormat": "p95" },
          { "expr": "histogram_quantile(0.99, sum(rate(a2a_tool_execution_latency_percentile_bucket[5m])) by (le))", "legendFormat": "p99" }
        ],
        "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
        "fieldConfig": { "defaults": { "unit": "ms" } }
      },
      {
        "id": 17, "title": "按工具分类的错误类型", "type": "bargauge",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 41 },
        "targets": [
          { "expr": "sum(rate(a2a_tool_error_type[5m])) by (tool, error)", "legendFormat": "{{tool}} - {{error}}" }
        ],
        "options": {
          "showThresholdLabels": false,
          "showThresholdMarkers": true,
          "orientation": "horizontal",
          "reduceOptions": { "values": false, "calcs": ["sum"] }
        },
        "fieldConfig": {
          "defaults": { "unit": "cps", "min": 0 },
          "overrides": [
            { "matcher": { "id": "byRegexp", "options": ".*retryable.*" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f2cc60" } }] },
            { "matcher": { "id": "byRegexp", "options": ".*fatal.*" },
              "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#e24d42" } }] }
          ]
        }
      }
    ]
  },
  "inputs": []
}
